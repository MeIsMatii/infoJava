# EditorConfig helps maintain consistent coding styles for multiple developers 
# working on the same project across various editors and IDEs.

root = true

[*]
# Use 4 spaces for indentation (standard for Java)
indent_style = space
indent_size = 4

# Use LF line endings for cross-platform compatibility
# (Linux, macOS, and modern Windows tools prefer LF)
end_of_line = lf

# Ensure files are saved with UTF-8 encoding
charset = utf-8

# Clean up files on save
trim_trailing_whitespace = true
insert_final_newline = true

# Configuration for specific file types
[*.{xml,yml,json,properties}]
indent_size = 2